[settings]

# Django core
DEBUG = False
SERVER = True
SECRET_KEY = your-secret-key-here

# Allowed hosts — comma-separated; include your Render domain
ALLOWED_HOSTS = your-app.onrender.com, .localhost, 127.0.0.1

# Database — set to 'sqlite' or 'postgresql'
DB_ENGINE = sqlite
DB_NAME = onaiza
DB_USER = postgres
DB_PASSWORD = your-db-password
DB_HOST = localhost
DB_PORT = 5432

# Google Maps API
PLACES_MAPS_API_KEY = your-google-maps-api-key

# Encryption & payment keys
PASSWORD_ENCRYPTION_KEY = your-encryption-key
RZP_ID_KEY = your-razorpay-id-key
RZP_SECRET_KEY = your-razorpay-secret-key
